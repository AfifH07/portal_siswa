# ==============================================
# Portal Siswa Baron - Staging Environment
# For: PythonAnywhere (SQLite)
# Copy this file to .env and update values
# ==============================================

# Django Core
DEBUG=False
SECRET_KEY=your-staging-secret-key-generate-with-django
ALLOWED_HOSTS=yourusername.pythonanywhere.com

# Database
# NOTE: Leave DATABASE_URL empty/commented to use SQLite
# DATABASE_URL=
# SQLite will be used automatically (db.sqlite3)

# JWT Configuration
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# CORS (PythonAnywhere domain)
CORS_ALLOWED_ORIGINS=https://yourusername.pythonanywhere.com

# Static Files (PythonAnywhere paths)
STATIC_URL=/static/
STATIC_ROOT=/home/yourusername/portal-siswa/backend_django/staticfiles/

# Security Headers (PythonAnywhere handles SSL)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# Template Directory (PythonAnywhere absolute path)
# TEMPLATE_DIR=/home/yourusername/portal-siswa/frontend/views

# Email Configuration (optional - for password reset)
# Leave empty to log tokens instead of sending email
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=

# ==============================================
# QUICK SETUP FOR PYTHONANYWHERE:
# 1. Copy this file: cp .env.staging.example .env
# 2. Replace 'yourusername' with your actual username
# 3. Generate SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# 4. Run migrations: python manage.py migrate
# 5. Collect static: python manage.py collectstatic
# ==============================================
