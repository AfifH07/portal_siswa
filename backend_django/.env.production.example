# ==============================================
# Portal Siswa Baron - Production Environment
# For: VPS/Cloud Server (PostgreSQL)
# Copy this file to .env and update values
# ==============================================

# Django Core
DEBUG=False
SECRET_KEY=your-production-secret-key-use-django-get-random-secret-key
ALLOWED_HOSTS=portal.pesantrenbaron.ac.id,www.pesantrenbaron.ac.id

# ==============================================
# DATABASE (PostgreSQL)
# ==============================================
# Format: postgres://USER:PASSWORD@HOST:PORT/DBNAME
#
# Local PostgreSQL:
# DATABASE_URL=postgres://portal_user:secure_password@localhost:5432/portal_siswa
#
# Remote PostgreSQL (e.g., Supabase, Neon, Railway):
# DATABASE_URL=postgres://user:pass@db.provider.com:5432/database?sslmode=require
#
# PythonAnywhere PostgreSQL:
# DATABASE_URL=postgres://username:password@username-1234.postgres.pythonanywhere-services.com:12345/dbname
#
DATABASE_URL=postgres://portal_user:your-secure-password@localhost:5432/portal_siswa_prod

# ==============================================
# JWT CONFIGURATION
# ==============================================
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=1440

# ==============================================
# CORS & SECURITY
# ==============================================
CORS_ALLOWED_ORIGINS=https://portal.pesantrenbaron.ac.id

# Security Headers (enable all for production)
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ==============================================
# STATIC FILES
# ==============================================
STATIC_URL=/static/
STATIC_ROOT=/var/www/portal-siswa/static/

# ==============================================
# EMAIL (for password reset)
# ==============================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=admin@pesantrenbaron.ac.id
EMAIL_HOST_PASSWORD=your-gmail-app-password
DEFAULT_FROM_EMAIL=Portal Ponpes Baron <noreply@pesantrenbaron.ac.id>
PASSWORD_RESET_TOKEN_EXPIRY=30

# ==============================================
# MONITORING (optional)
# ==============================================
# SENTRY_DSN=https://xxx@sentry.io/xxx

# ==============================================
# PRODUCTION DEPLOYMENT CHECKLIST:
# 1. Generate new SECRET_KEY (never reuse from staging!)
# 2. Set up PostgreSQL database and update DATABASE_URL
# 3. Configure domain in ALLOWED_HOSTS
# 4. Set up Gmail App Password for email
# 5. Run: python manage.py migrate
# 6. Run: python manage.py collectstatic --noinput
# 7. Configure Gunicorn + Nginx
# ==============================================
