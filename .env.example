# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASS=password
DB_NAME=portal_siswa
DB_DIALECT=mysql
DB_PORT=3306

# Server Configuration
PORT=3000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
